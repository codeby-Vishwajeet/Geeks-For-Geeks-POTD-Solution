class Solution {
  public:
    int visibleBuildings(vector<int>& arr) {
        if (arr.empty()) return 0;
        
        int count = 1; // The first building always gets sunlight
        int max_height = arr[0]; // Track the tallest building seen so far
        
        for (int i = 1; i < arr.size(); i++) {
            // If the current building is at least as tall as the max height seen
            if (arr[i] >= max_height) {
                count++;
                max_height = arr[i]; // Update the new max height
            }
        }
        
        return count;
    }
};
