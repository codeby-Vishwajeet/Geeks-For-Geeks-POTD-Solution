class Solution {
public:
    vector<int> reducePairs(vector<int>& arr) {
        vector<int> st; // We use a vector to simulate the stack
        
        for (int x : arr) {
            bool push_x = true;
            
            // While stack is not empty and there is an opposite sign collision
            while (!st.empty() && ((st.back() > 0 && x < 0) || (st.back() < 0 && x > 0))) {
                
                if (abs(st.back()) < abs(x)) {
                    // Top element is smaller, it gets destroyed
                    st.pop_back();
                } 
                else if (abs(st.back()) == abs(x)) {
                    // Both have the same absolute value, both get destroyed
                    st.pop_back();
                    push_x = false;
                    break;
                } 
                else {
                    // Top element is larger, x gets destroyed
                    push_x = false;
                    break;
                }
            }
            
            // If x survived the collisions, push it to our result array
            if (push_x) {
                st.push_back(x);
            }
        }
        
        return st;
    }
};
